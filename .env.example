# LLM Configuration
USE_MOCK_LLM=True
OPENAI_API_KEY=your_openai_api_key_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=loan_agent_db

# Risk Thresholds
THRESHOLD_APPROVE=0.4
THRESHOLD_REJECT=0.7

# Plaid Configuration (Get from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ENV=sandbox

# Credit Bureau Mock API
CREDIT_BUREAU_API_URL=http://localhost:8001
CREDIT_BUREAU_API_KEY=mock_api_key_12345

# File Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
